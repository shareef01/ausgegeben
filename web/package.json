{
  "name": "ausgegeben-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "npm run icons",
    "deploy": "npm run build && npx firebase deploy --only hosting:aus01,firestore:rules,firestore:indexes --config ../firebase.json",
    "deploy:hosting": "npm run build && npx firebase deploy --only hosting:aus01 --config ../firebase.json",
    "deploy:rules": "npx firebase deploy --only firestore:rules,firestore:indexes --config ../firebase.json"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.3",
    "firebase-tools": "^15.24.0",
    "playwright": "^1.61.1",
    "sharp": "^0.35.2",
    "typescript": "~5.8.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
