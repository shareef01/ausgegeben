VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional. Unused on Spark — Cloud Storage requires Blaze (since 2026-02-03).
# Receipts stay in the browser (IndexedDB); do not enable Storage unless you upgrade.
# VITE_FIREBASE_STORAGE_BUCKET=

# Optional App Check (reCAPTCHA Enterprise). Leave empty on Spark unless CSP is updated.
# VITE_FIREBASE_APP_CHECK_KEY=
