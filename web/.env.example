VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional. Unused on Spark — Cloud Storage requires Blaze (since 2026-02-03).
# Receipts stay in the browser (IndexedDB); do not enable Storage unless you upgrade.
# VITE_FIREBASE_STORAGE_BUCKET=

# Optional App Check (reCAPTCHA Enterprise). Hosting CSP already allows google.com / recaptcha.
# Leave empty on Spark unless you enable App Check in Firebase (~10K free assessments/mo).
# VITE_FIREBASE_APP_CHECK_KEY=
