rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTransactionType(value) {
      return value in ['expense', 'income', 'transfer'];
    }

    function isThemeMode(value) {
      return value in [
        'system', 'light', 'dark', 'amoled', 'midnight',
        'ocean', 'forest', 'sunset', 'lavender', 'soft_light'
      ];
    }

    function isOptionalReceiptPath(value) {
      return value == null
        || (value is string
          && value.size() <= 512
          && (value.size() == 0 || value.matches('receipt://.+')));
    }

    function isValidCategory(data) {
      return data.keys().hasAll([
          'cloudId', 'name', 'iconName', 'colorInt',
          'transactionType', 'sortOrder', 'updatedAt', 'deleted'
        ])
        && data.cloudId is string
        && data.cloudId.size() > 0
        && data.cloudId.size() <= 64
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.iconName is string
        && data.iconName.size() > 0
        && data.iconName.size() <= 64
        && data.colorInt is int
        && data.colorInt >= -2147483648
        && data.colorInt <= 2147483647
        && data.transactionType is string
        && isTransactionType(data.transactionType)
        && data.sortOrder is int
        && data.sortOrder >= -10000
        && data.sortOrder <= 10000
        && data.deleted is bool
        && data.updatedAt is timestamp;
    }

    function isValidExpense(data) {
      return data.keys().hasAll([
          'cloudId', 'amount', 'dateMillis', 'categoryId', 'categoryCloudId',
          'note', 'transactionType', 'updatedAt', 'deleted'
        ])
        && data.cloudId is string
        && data.cloudId.size() > 0
        && data.cloudId.size() <= 64
        && data.amount is number
        && data.amount >= -999999999
        && data.amount <= 999999999
        && data.dateMillis is int
        && data.dateMillis >= 0
        && data.dateMillis <= 4102444800000
        && data.categoryId is int
        && data.categoryCloudId is string
        && data.categoryCloudId.size() > 0
        && data.categoryCloudId.size() <= 64
        && data.note is string
        && data.note.size() <= 2000
        && (!('receiptImagePath' in data) || isOptionalReceiptPath(data.receiptImagePath))
        && data.transactionType is string
        && isTransactionType(data.transactionType)
        && data.deleted is bool
        && data.updatedAt is timestamp;
    }

    function isValidPreferences(data) {
      return data.keys().hasAll([
          'currency', 'locale', 'themeMode', 'dailyReminder',
          'reminderHour', 'reminderMinute', 'analyticsPeriod',
          'recordListPeriod', 'updatedAt'
        ])
        && data.currency is string
        && data.currency.size() >= 3
        && data.currency.size() <= 8
        && data.locale is string
        && data.locale in ['en', 'de']
        && data.themeMode is string
        && isThemeMode(data.themeMode)
        && data.dailyReminder is bool
        && data.reminderHour is int
        && data.reminderHour >= 0
        && data.reminderHour <= 23
        && data.reminderMinute is int
        && data.reminderMinute >= 0
        && data.reminderMinute <= 59
        && data.analyticsPeriod is string
        && data.analyticsPeriod.size() <= 64
        && data.recordListPeriod is string
        && data.recordListPeriod.size() <= 64
        && (!('monthlyBudget' in data)
          || data.monthlyBudget == null
          || (data.monthlyBudget is number
            && data.monthlyBudget > 0
            && data.monthlyBudget <= 999999999))
        && data.updatedAt is timestamp;
    }

    function isValidUserMeta(data) {
      return (!('lastPushAt' in data)
          || (data.lastPushAt is number && data.lastPushAt > 0 && data.lastPushAt <= 4102444800000))
        && (!('lastPullAt' in data)
          || (data.lastPullAt is number && data.lastPullAt > 0 && data.lastPullAt <= 4102444800000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserMeta(request.resource.data);
      allow delete: if false;

      match /preferences/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && docId == 'settings'
          && isValidPreferences(request.resource.data);
        allow delete: if false;
      }

      match /categories/{categoryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && categoryId == request.resource.data.cloudId
          && isValidCategory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /expenses/{expenseId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && expenseId == request.resource.data.cloudId
          && isValidExpense(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
